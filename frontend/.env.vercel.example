# Vercel (frontend) uchun environment variables
# Vercel Dashboard -> Settings -> Environment Variables

# Google Maps (majburiy — xarita uchun)
VITE_GOOGLE_MAPS_API_KEY=your-google-api-key

# Backend alohida serverda ishlashi kerak (Docker/VPS/Railway)
# Masalan: https://api.sizning-domen.uz/api/v1
VITE_API_URL=https://YOUR-BACKEND-SERVER/api/v1

# WebSocket — live kamera uchun (backend server manzili)
# Masalan: wss://api.sizning-domen.uz/api/v1
VITE_WS_URL=wss://YOUR-BACKEND-SERVER/api/v1
