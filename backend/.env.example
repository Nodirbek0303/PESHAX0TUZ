INFERENCE_MODE=gpu
INFERENCE_DEVICE=auto
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.45
YOLO_IOU=0.5
USE_WEBCAM=false
WEBCAM_INDEX=0
WEBCAM_WIDTH=1280
WEBCAM_HEIGHT=720
CAMERA_STREAM_URLS={}
ENABLE_VISION_VEHICLE_DETECTION=true
VEHICLE_PROXIMITY_ALERT_SEC=2.0
SENSOR_STALE_AFTER_SEC=15
GOOGLE_API_KEY=your-google-api-key
ADMIN_PASSWORD=404-UZ_TEAM
# Production: ADMIN_PASSWORD o'rniga bcrypt hash ishlating
# ADMIN_PASSWORD_HASH=$2b$12$...
SECURITY_ENVIRONMENT=development
SECURITY_SECRET_KEY=change-me-in-production-use-64-char-random-secret-key!!
SECURITY_REQUIRE_SENSOR_KEY=false
SECURITY_ENABLE_DOCS=true
SECURITY_RATE_LIMIT_PER_MINUTE=120
SECURITY_LOGIN_MAX_ATTEMPTS=5
SECURITY_LOGIN_LOCKOUT_MINUTES=15
SENSOR_API_KEY=your-sensor-api-key
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://smartcross:smartcross@localhost:5432/smartcross
CORS_ORIGINS=["http://localhost","http://localhost:5173","http://127.0.0.1"]